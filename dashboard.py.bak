from flask import Flask, render_template_string, request, redirect, url_for, flash, jsonify, Blueprint, session
from database.models import db, User, Transaction, Rental
from datetime import datetime, timedelta
import os
import plotly.graph_objs as go
import plotly.utils
import json
from collections import defaultdict
import secrets
import logging
import sqlite3
import requests

logger = logging.getLogger(__name__)

# Tạo blueprint
dashboard_bp = Blueprint('dashboard', __name__)

app = Flask(__name__)
app.secret_key = secrets.token_hex(16)

# Cấu hình database
db_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'database', 'bot.db')
app.config['SQLALCHEMY_DATABASE_URI'] = f'sqlite:///{db_path}'
app.config['SQLALCHEMY_TRACK_MODIFICATIONS'] = False
db.init_app(app)

